{
  "name": "nep-college-erp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:clean",
    "dev:turbo": "turbo dev",
    "dev:infra": "node scripts/dev-infra.mjs",
    "dev:setup": "npm run dev:infra && npm run db:migrate && npm run db:seed",
    "dev:free-ports": "npx --yes kill-port 3000 3001",
    "dev:clean": "npm run dev:infra && npm run dev:free-ports && node -e \"process.env.API_HOST='127.0.0.1'; require('child_process').spawn('npx', ['turbo', 'dev'], { stdio: 'inherit', shell: true, env: process.env })\"",
    "dev:lan": "node scripts/dev-lan.mjs",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:ci": "turbo lint:ci",
    "check:exports-queue": "node scripts/ci/check-exports-queue-worker.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "typecheck": "turbo typecheck",
    "typecheck:gate": "node scripts/ci/run-web-typecheck-gate.mjs",
    "prepare": "husky",
    "db:generate": "npm run db:generate -w api",
    "db:migrate": "npm run db:migrate -w api",
    "db:seed": "npm run db:seed -w api",
    "load:test": "node scripts/load-test/run-k6.mjs pre-launch.js",
    "load:test:smoke": "node scripts/load-test/run-k6.mjs pre-launch-smoke.js",
    "demo:prepare": "npm run demo:prepare -w api",
    "demo:prepare:quick": "npm run demo:prepare:quick -w api"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "prisma": "^7.8.0",
    "turbo": "^2.5.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@prisma/client": "^7.8.0"
  }
}
