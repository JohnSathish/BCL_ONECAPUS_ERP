{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "tsBuildInfoFile": "./.cache/tsconfig.build.tsbuildinfo"
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "test",
    "dist",
    "**/*spec.ts",
    "prisma",
    "scripts",
    "prisma.config.ts"
  ]
}
