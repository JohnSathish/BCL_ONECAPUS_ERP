# Host port 15432 maps to Postgres in docker-compose (avoids conflict with local PostgreSQL on 5432).
DATABASE_URL=postgresql://nep:nep_dev_password@127.0.0.1:15432/nep_erp
REDIS_URL=redis://127.0.0.1:6379
PORT=3001
WEB_ORIGIN=http://localhost:3000
# Local dev: map localhost / 127.0.0.1 logins to this tenant domain (seed creates demo.localhost).
DEV_LOGIN_HOST=demo.localhost
# Comma-separated extra CORS origins for production (e.g. http://192.168.1.10:3000)
CORS_EXTRA_ORIGINS=

JWT_ACCESS_SECRET=change-me-access-min-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-min-32-characters-long
JWT_ACCESS_TTL=1200s
JWT_REFRESH_TTL=7d
JWT_REFRESH_TTL_REMEMBER=30d

# Email (optional — omit SMTP_HOST for dev-log mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@demo.edu

# Razorpay (optional — omit for office-only fee collection)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Storage (local disk default; set s3 or r2 for production object storage)
STORAGE_ROOT=storage
UPLOAD_ROOT=uploads
STORAGE_DRIVER=local
AWS_S3_BUCKET=
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
CDN_URL=

# Background jobs: api (default) processes BullMQ export jobs including receipt PDFs
PROCESS_BACKGROUND_JOBS=api

# Applicant portal password-reset links (optional — derived from request Host if unset)
ADMISSIONS_PORTAL_ORIGIN=http://admissions.demo.localhost:3000

# Firebase Cloud Messaging (optional — required for mobile PUSH channel)
# Local/dev: set FCM_DEMO_MODE=true to log pushes without Firebase credentials.
FCM_DEMO_MODE=true
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
# Use literal \n for newlines when storing the PEM in .env
FCM_PRIVATE_KEY=
