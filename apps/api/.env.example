# Host port 15432 maps to Postgres in docker-compose (avoids conflict with local PostgreSQL on 5432).
DATABASE_URL=postgresql://nep:nep_dev_password@127.0.0.1:15432/nep_erp
REDIS_URL=redis://127.0.0.1:6379
PORT=3001
WEB_ORIGIN=http://localhost:3000
# Local dev: map localhost / 127.0.0.1 logins to this tenant domain (seed creates demo.localhost).
DEV_LOGIN_HOST=demo.localhost
# Comma-separated extra CORS origins for production (e.g. http://192.168.1.10:3000)
CORS_EXTRA_ORIGINS=

JWT_ACCESS_SECRET=change-me-access-min-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-min-32-characters-long
JWT_ACCESS_TTL=1200s
JWT_REFRESH_TTL=7d
JWT_REFRESH_TTL_REMEMBER=30d

# Email (optional — omit SMTP_HOST for dev-log mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@demo.edu
