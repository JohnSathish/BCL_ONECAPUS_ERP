generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["platform", "core", "academic", "finance", "compliance", "library", "naac", "access"]
}

// --- platform ---

model Tenant {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  status    String    @default("active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  domains                       TenantDomain[]
  branding                      TenantBranding?
  themeSettings                 AppThemeSettings?
  users                         User[]
  roles                         Role[]
  auditLogs                     AuditLog[]
  loginAttempts                 LoginAttempt[]
  institutions                  Institution[]                 @relation("TenantInstitutions")
  refreshTokens                 RefreshSession[]
  usernameGenerationRules       UsernameGenerationRule[]
  rollNumberSettings            RollNumberSettings?
  studentDisplaySettings        StudentDisplaySettings?
  rollPrefixConfigs             RollPrefixConfig[]
  staffEmployeeCodeSettings     StaffEmployeeCodeSettings?
  staffEmployeeCodeTypePrefixes StaffEmployeeCodeTypePrefix[]
  securitySettings              TenantSecuritySettings?
  examinationSettings           TenantExaminationSettings?
  impersonationSessions         ImpersonationSession[]
  permissionAuditLogs           PermissionAuditLog[]
  tenantLicense                 TenantLicense?
  mobileAppSettings             MobileAppSettings?
  mobileAppReleases             MobileAppRelease[]
  mobileDevices                 MobileDevice[]
  mobileAppEvents               MobileAppEvent[]
  mobileAppDailyStats           MobileAppDailyStats[]
  backupSchedules               BackupSchedule[]
  backupRuns                    BackupRun[]

  @@map("tenants")
  @@schema("platform")
}

model TenantLicense {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @unique @map("tenant_id") @db.Uuid
  licenseNumber     String    @unique @map("license_number")
  licenseType       String    @map("license_type")
  subscriptionPlan  String    @map("subscription_plan")
  startDate         DateTime  @map("start_date") @db.Date
  expiryDate        DateTime? @map("expiry_date") @db.Date
  renewalDate       DateTime? @map("renewal_date") @db.Date
  gracePeriodDays   Int       @default(15) @map("grace_period_days")
  maxStudents       Int?      @map("max_students")
  maxStaff          Int?      @map("max_staff")
  storageLimitMb    Int?      @map("storage_limit_mb")
  internalNotes     String?   @map("internal_notes")
  suspendedAt       DateTime? @map("suspended_at")
  suspendedById     String?   @map("suspended_by_id") @db.Uuid
  suspensionReason  String?   @map("suspension_reason")
  createdById       String?   @map("created_by_id") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  renewals          LicenseRenewal[]
  notificationLogs  LicenseNotificationLog[]
  auditLogs         LicenseAuditLog[]
  activationKeys    LicenseActivationKey[]

  @@index([expiryDate])
  @@map("tenant_licenses")
  @@schema("platform")
}

model LicenseActivationKey {
  id                 String    @id @default(uuid()) @db.Uuid
  activationKey      String    @unique @map("activation_key")
  label              String?
  licenseType        String    @map("license_type")
  subscriptionPlan   String    @map("subscription_plan")
  termDays           Int       @map("term_days")
  gracePeriodDays    Int       @default(15) @map("grace_period_days")
  maxStudents        Int?      @map("max_students")
  maxStaff           Int?      @map("max_staff")
  storageLimitMb     Int?      @map("storage_limit_mb")
  status             String    @default("PENDING")
  keyExpiresAt       DateTime? @map("key_expires_at")
  redeemedAt         DateTime? @map("redeemed_at")
  redeemedByTenantId String?   @map("redeemed_by_tenant_id") @db.Uuid
  redeemedByUserId   String?   @map("redeemed_by_user_id") @db.Uuid
  tenantLicenseId    String?   @map("tenant_license_id") @db.Uuid
  internalNotes      String?   @map("internal_notes")
  createdById        String?   @map("created_by_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  tenantLicense TenantLicense? @relation(fields: [tenantLicenseId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([redeemedByTenantId])
  @@map("license_activation_keys")
  @@schema("platform")
}

model LicenseRenewal {
  id                  String    @id @default(uuid()) @db.Uuid
  tenantLicenseId     String    @map("tenant_license_id") @db.Uuid
  renewedAt           DateTime  @default(now()) @map("renewed_at")
  previousExpiryDate  DateTime? @map("previous_expiry_date") @db.Date
  newExpiryDate       DateTime? @map("new_expiry_date") @db.Date
  amount              Decimal?  @db.Decimal(12, 2)
  invoiceNumber       String?   @map("invoice_number")
  paymentMode         String?   @map("payment_mode")
  notes               String?
  updatedById         String?   @map("updated_by_id") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at")

  tenantLicense TenantLicense @relation(fields: [tenantLicenseId], references: [id], onDelete: Cascade)

  @@index([tenantLicenseId, renewedAt])
  @@map("license_renewals")
  @@schema("platform")
}

model LicenseNotificationLog {
  id              String   @id @default(uuid()) @db.Uuid
  tenantLicenseId String   @map("tenant_license_id") @db.Uuid
  milestoneDays   Int      @map("milestone_days")
  channel         String
  sentAt          DateTime @default(now()) @map("sent_at")

  tenantLicense TenantLicense @relation(fields: [tenantLicenseId], references: [id], onDelete: Cascade)

  @@unique([tenantLicenseId, milestoneDays, channel])
  @@map("license_notification_logs")
  @@schema("platform")
}

model LicenseAuditLog {
  id              String   @id @default(uuid()) @db.Uuid
  tenantLicenseId String   @map("tenant_license_id") @db.Uuid
  action          String
  previousValue   Json?    @map("previous_value")
  newValue        Json?    @map("new_value")
  actorId         String?  @map("actor_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  tenantLicense TenantLicense @relation(fields: [tenantLicenseId], references: [id], onDelete: Cascade)

  @@index([tenantLicenseId, createdAt])
  @@map("license_audit_logs")
  @@schema("platform")
}

model TenantBranding {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @unique @map("tenant_id") @db.Uuid
  displayName          String   @map("display_name")
  shortName            String?  @map("short_name")
  campusName           String?  @map("campus_name")
  portalSubtitle       String?  @map("portal_subtitle")
  address              String?
  logoUrl              String?  @map("logo_url")
  faviconUrl           String?  @map("favicon_url")
  primaryColor         String?  @map("primary_color")
  accentColor          String?  @map("accent_color")
  sidebarColor         String?  @map("sidebar_color")
  loginBackgroundStyle String   @default("gradient") @map("login_background_style")
  showPoweredBy        Boolean  @default(true) @map("show_powered_by")
  brandingEnabled      Boolean  @default(true) @map("branding_enabled")
  badges               Json     @default("[]")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_branding")
  @@schema("platform")
}

model AppThemeSettings {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @unique @map("tenant_id") @db.Uuid
  themeName        String   @default("dbc-enterprise-blue") @map("theme_name")
  primaryColor     String?  @map("primary_color")
  sidebarBg        String?  @map("sidebar_bg")
  sidebarText      String?  @map("sidebar_text")
  sidebarActive    String?  @map("sidebar_active")
  topbarBg         String?  @map("topbar_bg")
  cardBg           String?  @map("card_bg")
  borderColor      String?  @map("border_color")
  accentColor      String?  @map("accent_color")
  fontFamily       String?  @map("font_family")
  logoUrl          String?  @map("logo_url")
  darkModeEnabled  Boolean  @default(true) @map("dark_mode_enabled")
  compactSidebar   Boolean  @default(false) @map("compact_sidebar")
  roundedStyle     String   @default("xl") @map("rounded_style")
  appearanceMode   String   @default("system") @map("appearance_mode")
  layoutJson       Json     @default("{}") @map("layout_json")
  customCss        String?  @map("custom_css") @db.Text
  customCssEnabled Boolean  @default(false) @map("custom_css_enabled")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("app_theme_settings")
  @@schema("platform")
}

model CampusThemeSettings {
  id        String   @id @default(uuid()) @db.Uuid
  campusId  String   @unique @map("campus_id") @db.Uuid
  overrides Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  campus Campus @relation(fields: [campusId], references: [id], onDelete: Cascade)

  @@map("campus_theme_settings")
  @@schema("core")
}

model LoginAttempt {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  ipAddress     String    @map("ip_address")
  email         String
  failedCount   Int       @default(0) @map("failed_count")
  lockedUntil   DateTime? @map("locked_until")
  lastAttemptAt DateTime  @default(now()) @map("last_attempt_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, ipAddress, email])
  @@index([tenantId, ipAddress])
  @@map("login_attempts")
  @@schema("platform")
}

model TenantDomain {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  host      String    @unique
  verified  Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_domains")
  @@schema("platform")
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  email             String
  username          String?
  phone             String?
  displayName       String?   @map("display_name")
  passwordHash      String    @map("password_hash")
  emailVerifiedAt   DateTime? @map("email_verified_at")
  isActive          Boolean   @default(true) @map("is_active")
  accountStatus     String    @default("active") @map("account_status")
  lastLoginAt       DateTime? @map("last_login_at")
  passwordChangedAt DateTime? @map("password_changed_at")
  mustResetPassword Boolean   @default(false) @map("must_reset_password")
  mfaEnabled        Boolean   @default(false) @map("mfa_enabled")
  appearanceMode    String    @default("system") @map("appearance_mode")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  tenant                         Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles                          UserRole[]
  shiftAssignments               UserShiftAssignment[]
  identities                     UserIdentity[]
  refreshSessions                RefreshSession[]
  mobileDevices                  MobileDevice[]
  passwordHistory                PasswordHistory[]
  passwordResetTokens            PasswordResetToken[]
  mfaSecret                      UserMfaSecret?
  mfaRecoveryCodes               UserMfaRecoveryCode[]
  impersonationsAsAdmin          ImpersonationSession[]      @relation("ImpersonationAdmin")
  impersonationsAsTarget         ImpersonationSession[]      @relation("ImpersonationTarget")
  auditLogs                      AuditLog[]                  @relation("AuditActor")
  shiftsCreated                  Shift[]                     @relation("ShiftCreatedBy")
  student                        Student?
  staffProfile                   StaffProfile?
  shiftTransfersApproved         StudentShiftTransfer[]      @relation("ShiftTransferApprover")
  semestersFrozen                Semester[]                  @relation("SemesterFrozenBy")
  activeSemestersActivated       CampusShiftActiveSemester[] @relation("ActiveSemesterActivatedBy")
  promotionRunsApplied           SemesterPromotionRun[]      @relation("PromotionRunAppliedBy")
  promotionAuditLogs             SemesterPromotionAuditLog[] @relation("PromotionAuditActor")
  cycleSwitches                  InstitutionAcademicConfig[] @relation("CycleSwitchBy")
  studentDocumentsUploaded       StudentDocument[]           @relation("StudentDocumentUploadedBy")
  studentDocumentsVerified       StudentDocument[]           @relation("StudentDocumentVerifiedBy")
  staffDocumentsUploaded         StaffDocument[]             @relation("StaffDocumentUploadedBy")
  staffDocumentsVerified         StaffDocument[]             @relation("StaffDocumentVerifiedBy")
  substituteStaffCreated         SubstituteStaff[]           @relation("SubstituteStaffCreatedBy")
  studentsCreated                Student[]                   @relation("StudentCreatedBy")
  studentsModified               Student[]                   @relation("StudentModifiedBy")
  studentProfileAuditLogs        StudentProfileAuditLog[]    @relation("ProfileAuditActor")
  studentBulkUpdateBatches       StudentBulkUpdateBatch[]    @relation("BulkUpdateActor")
  staffBulkUpdateBatches         StaffBulkUpdateBatch[]      @relation("StaffBulkUpdateActor")
  studentPhotoBulkBatches        StudentPhotoBulkBatch[]     @relation("PhotoBulkActor")
  studentRollNumberAuditLogs     StudentRollNumberAuditLog[] @relation("RollNumberAuditActor")
  staffEmployeeCodeAuditLogs     StaffEmployeeCodeAuditLog[] @relation("EmployeeCodeAuditActor")
  studentLifecycleEvents         StudentLifecycleEvent[]     @relation("StudentLifecycleActor")
  studentRemarks                 StudentRemark[]             @relation("StudentRemarkActor")
  studentAcademicTracksSelected  StudentAcademicTrack[]      @relation("StudentAcademicTrackSelectedBy")
  majorMinorTracksUnlocked       StudentMajorMinorTrack[]    @relation("MajorMinorTrackUnlockedBy")
  vtcTracksReset                 StudentVtcTrack[]           @relation("VtcTrackResetBy")
  registrationLinesAssigned      SemesterRegistrationLine[]  @relation("RegistrationLineAssignedBy")
  programVersionsCreated         ProgramVersion[]            @relation("ProgramVersionCreatedBy")
  programVersionsArchived        ProgramVersion[]            @relation("ProgramVersionArchivedBy")
  fyugpStructureTemplatesCreated FyugpStructureTemplate[]    @relation("FyugpStructureTemplateCreatedBy")
  categoryPoolsCreated           CategoryPool[]              @relation("CategoryPoolCreatedBy")
  subjectTeachingAssignments     SubjectTeachingAssignment[] @relation("SubjectTeachingAssignmentCreatedBy")
  lmsMaterialsUploaded           LmsMaterial[]               @relation("LmsMaterialUploadedBy")
  lmsAnnouncementsCreated        LmsAnnouncement[]           @relation("LmsAnnouncementCreatedBy")
  lmsLessonPlansCreated          LmsLessonPlan[]             @relation("LmsLessonPlanCreatedBy")
  lmsAssignmentsCreated          LmsAssignment[]             @relation("LmsAssignmentCreatedBy")
  lmsQuizzesCreated              LmsQuiz[]                   @relation("LmsQuizCreatedBy")
  lmsDiscussionsCreated          LmsDiscussion[]             @relation("LmsDiscussionCreatedBy")
  lmsDiscussionRepliesCreated    LmsDiscussionReply[]        @relation("LmsDiscussionReplyCreatedBy")
  lmsAssignmentFeedbackGiven     LmsAssignmentFeedback[]     @relation("LmsAssignmentFeedbackBy")
  lmsAuditLogs                   LmsAuditLog[]               @relation("LmsAuditLogActor")
  communicationTemplatesCreated  CommunicationTemplate[]     @relation("CommunicationTemplateCreatedBy")
  communicationCampaignsCreated  CommunicationCampaign[]     @relation("CommunicationCampaignCreatedBy")
  communicationRecipients        CommunicationRecipient[]    @relation("CommunicationRecipientUser")
  userNotifications              UserNotification[]
  notificationPreferences        NotificationPreference[]
  userPermissions                UserPermission[]
  permissionAuditLogs            PermissionAuditLog[]        @relation("PermissionAuditActor")
  applicantApplication           AdmissionApplication?       @relation("ApplicantUser")
  admissionDocumentsVerified     AdmissionApplicationDocument[] @relation("AdmissionDocVerifiedBy")
  admissionAuditLogs             AdmissionAuditLog[]         @relation("AdmissionAuditActor")

  @@unique([tenantId, email])
  @@unique([tenantId, username])
  @@index([tenantId])
  @@index([tenantId, accountStatus])
  @@map("users")
  @@schema("platform")
}

model UserIdentity {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  provider       String
  providerUserId String    @map("provider_user_id")
  metadata       Json?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("user_identities")
  @@schema("platform")
}

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  slug        String
  name        String
  description String?
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  userRoles   UserRole[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("roles")
  @@schema("platform")
}

model Permission {
  id          String    @id @default(uuid()) @db.Uuid
  slug        String    @unique
  resource    String
  action      String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  roles RolePermission[]
  userPermissions UserPermission[]

  @@map("permissions")
  @@schema("platform")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
  @@schema("platform")
}

model UserRole {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  roleId       String    @map("role_id") @db.Uuid
  campusId     String?   @map("campus_id") @db.Uuid
  shiftId      String?   @map("shift_id") @db.Uuid
  departmentId String?   @map("department_id") @db.Uuid
  programmeId  String?   @map("programme_id") @db.Uuid
  semesterNo   Int?      @map("semester_no")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role  Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  shift Shift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([roleId])
  @@index([shiftId])
  @@index([departmentId])
  @@index([programmeId])
  @@map("user_roles")
  @@schema("platform")
}

model UserPermission {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  effect       String   @default("grant")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@map("user_permissions")
  @@schema("platform")
}

model PermissionAuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  roleSlug       String?  @map("role_slug")
  permissionSlug String?  @map("permission_slug")
  module         String?
  action         String
  outcome        String   @default("allowed")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation("PermissionAuditActor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, userId])
  @@map("permission_audit_logs")
  @@schema("platform")
}

model UserShiftAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  shiftId   String   @map("shift_id") @db.Uuid
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@unique([userId, shiftId])
  @@index([shiftId])
  @@map("user_shift_assignments")
  @@schema("platform")
}

model RefreshSession {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  familyId     String    @map("family_id") @db.Uuid
  jti          String    @unique
  hashedToken  String    @map("hashed_token")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?   @map("replaced_by_id") @db.Uuid
  userAgent    String?   @map("user_agent")
  ipAddress    String?   @map("ip_address")
  metadata     Json      @default("{}")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, familyId])
  @@index([tenantId])
  @@map("refresh_sessions")
  @@schema("platform")
}

model MobileAppSettings {
  id                     String   @id @default(uuid()) @db.Uuid
  tenantId               String   @unique @map("tenant_id") @db.Uuid
  studentAppName         String   @default("Student App") @map("student_app_name")
  staffAppName           String   @default("Staff App") @map("staff_app_name")
  studentMinVersion      String   @default("1.0.0") @map("student_min_version")
  studentLatestVersion   String   @default("1.0.0") @map("student_latest_version")
  staffMinVersion        String   @default("1.0.0") @map("staff_min_version")
  staffLatestVersion     String   @default("1.0.0") @map("staff_latest_version")
  studentMaintenanceMode Boolean @default(false) @map("student_maintenance_mode")
  staffMaintenanceMode   Boolean @default(false) @map("staff_maintenance_mode")
  maintenanceMessage     String?  @map("maintenance_message")
  studentForceUpdate     Boolean  @default(false) @map("student_force_update")
  staffForceUpdate       Boolean  @default(false) @map("staff_force_update")
  forceUpdateMessage     String?  @map("force_update_message")
  studentDashboardConfig Json     @default("{}") @map("student_dashboard_config")
  staffDashboardConfig   Json     @default("{}") @map("staff_dashboard_config")
  brandingOverrides      Json     @default("{}") @map("branding_overrides")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("mobile_app_settings")
  @@schema("platform")
}

model MobileAppRelease {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  appType      String   @map("app_type")
  version      String
  releaseNotes String?  @map("release_notes")
  publishedAt  DateTime @default(now()) @map("published_at")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, appType])
  @@map("mobile_app_releases")
  @@schema("platform")
}

model MobileDevice {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
