  @@unique([tenantId, passNumber])
  @@index([tenantId])
  @@map("library_visitors")
  @@schema("library")
}

model LibraryVisit {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  memberType      String    @map("member_type")
  studentId       String?   @map("student_id") @db.Uuid
  staffProfileId  String?   @map("staff_profile_id") @db.Uuid
  visitorId       String?   @map("visitor_id") @db.Uuid
  entryAt         DateTime  @default(now()) @map("entry_at")
  exitAt          DateTime? @map("exit_at")
  durationMinutes Int?      @map("duration_minutes")
