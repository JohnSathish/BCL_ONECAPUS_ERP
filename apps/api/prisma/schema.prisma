  status         String   @default("PENDING")
  payrollRunId   String?  @map("payroll_run_id") @db.Uuid
  payslipId      String?  @map("payslip_id") @db.Uuid
  createdById    String?  @map("created_by_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  quarter      StaffQuarter      @relation(fields: [quarterId], references: [id], onDelete: Restrict)
  staffProfile StaffProfile      @relation(fields: [staffProfileId], references: [id], onDelete: Restrict)
  occupancy    QuarterOccupancy? @relation(fields: [occupancyId], references: [id], onDelete: SetNull)

  @@index([tenantId, billingYear, billingMonth, status])
  @@map("quarter_monthly_charges")
  @@schema("academic")
}

