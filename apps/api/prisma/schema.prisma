  incidents LibraryCopyIncident[] @relation("IncidentCopy")
  replacementIncidents LibraryCopyIncident[] @relation("ReplacementCopy")

  @@unique([tenantId, barcode])
  @@unique([tenantId, bookId, copyNumber])
  @@index([tenantId, status])
  @@map("library_book_copies")
  @@schema("library")
}

model LibraryLoan {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  copyId         String    @map("copy_id") @db.Uuid
  memberType     String    @map("member_type")
  studentId      String?   @map("student_id") @db.Uuid
  staffProfileId String?   @map("staff_profile_id") @db.Uuid
  issuedAt       DateTime  @default(now()) @map("issued_at")
  dueAt          DateTime  @map("due_at")
  returnedAt     DateTime? @map("returned_at")
