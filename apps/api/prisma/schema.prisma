// --- campus access (CAMS) ---

model AccessPoint {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  code            String
  name            String
  accessType      String    @map("access_type")
  location        String?
  active          Boolean   @default(true)
  blockOnFine     Boolean   @default(false) @map("block_on_fine")
  blockInactive   Boolean   @default(true) @map("block_inactive")
  attendanceMode  Boolean   @default(false) @map("attendance_mode")
  voiceEnabled    Boolean   @default(true) @map("voice_enabled")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  devices AccessKioskDevice[]
  logs    EntryExitLog[]
  passes  VisitorPass[]

  @@unique([tenantId, code])
  @@index([tenantId, active])
