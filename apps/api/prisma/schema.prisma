// ─── Staff Accommodation & Quarters ───────────────────────────────────────────

model QuarterTypeConfig {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  slug      String
  name      String
  isSystem  Boolean  @default(false) @map("is_system")
  sortOrder Int      @default(100) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("quarter_type_configs")
  @@schema("academic")
}

model StaffQuarter {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  code               String
  quarterNumber      String    @map("quarter_number")
  quarterType        String    @map("quarter_type")
  block              String?
  floor              String?
  numberOfRooms      Int?      @map("number_of_rooms")
  status             String    @default("VACANT")
  monthlyRent        Decimal   @default(0) @map("monthly_rent") @db.Decimal(12, 2)
  waterCharge        Decimal   @default(0) @map("water_charge") @db.Decimal(12, 2)
  electricityCharge  Decimal   @default(0) @map("electricity_charge") @db.Decimal(12, 2)
  maintenanceCharge  Decimal   @default(0) @map("maintenance_charge") @db.Decimal(12, 2)
  internetCharge     Decimal   @default(0) @map("internet_charge") @db.Decimal(12, 2)
  remarks            String?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  occupancies    QuarterOccupancy[]
  monthlyCharges QuarterMonthlyCharge[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, quarterType])
  @@map("staff_quarters")
  @@schema("academic")
}

model QuarterOccupancy {
  id                      String    @id @default(uuid()) @db.Uuid
  tenantId                String    @map("tenant_id") @db.Uuid
  quarterId               String    @map("quarter_id") @db.Uuid
  staffProfileId          String    @map("staff_profile_id") @db.Uuid
  status                  String    @default("ACTIVE")
  allottedAt              DateTime  @map("allotted_at") @db.Date
  vacatedAt               DateTime? @map("vacated_at") @db.Date
  monthlyRent             Decimal   @default(0) @map("monthly_rent") @db.Decimal(12, 2)
  waterCharge             Decimal   @default(0) @map("water_charge") @db.Decimal(12, 2)
  electricityCharge       Decimal   @default(0) @map("electricity_charge") @db.Decimal(12, 2)
  maintenanceCharge       Decimal   @default(0) @map("maintenance_charge") @db.Decimal(12, 2)
  internetCharge          Decimal   @default(0) @map("internet_charge") @db.Decimal(12, 2)
  payrollDeductionEnabled Boolean   @default(true) @map("payroll_deduction_enabled")
  finalMeterReading       String?   @map("final_meter_reading")
  finalCharges            Decimal?  @map("final_charges") @db.Decimal(12, 2)
  notes                   String?
  vacateNotes             String?   @map("vacate_notes")
  createdById             String?   @map("created_by_id") @db.Uuid
  vacatedById             String?   @map("vacated_by_id") @db.Uuid
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  quarter        StaffQuarter           @relation(fields: [quarterId], references: [id], onDelete: Restrict)
  staffProfile   StaffProfile           @relation(fields: [staffProfileId], references: [id], onDelete: Restrict)
  monthlyCharges QuarterMonthlyCharge[]

  @@index([tenantId, staffProfileId, status])
  @@index([tenantId, quarterId, status])
  @@map("quarter_occupancies")
  @@schema("academic")
}

model QuarterMonthlyCharge {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  quarterId      String   @map("quarter_id") @db.Uuid
  staffProfileId String   @map("staff_profile_id") @db.Uuid
  occupancyId    String?  @map("occupancy_id") @db.Uuid
  chargeType     String   @map("charge_type")
  billingMonth   Int      @map("billing_month")
  billingYear    Int      @map("billing_year")
