  @@index([tenantId, memberType, visitorId, exitAt])
  @@index([tenantId, entryAt])
  @@index([tenantId, exitAt])
  @@map("library_visits")
  @@schema("library")
}

model LibraryBook {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  accessionNo    String    @map("accession_no")
  bookNumber     String?   @map("book_number")
  isbn           String?
  title          String
  author         String?
  publisher      String?
  edition        String?
  departmentId   String?   @map("department_id") @db.Uuid
  categoryId     String?   @map("category_id") @db.Uuid
  price          Decimal?  @db.Decimal(12, 2)
  shelf          String?
  rack           String?
  section        String?
  row            String?
  location       String?
  accessionStatus String  @default("ON_SHELF") @map("accession_status")
  status         String    @default("ACTIVE")
  totalCopies    Int       @default(1) @map("total_copies")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

