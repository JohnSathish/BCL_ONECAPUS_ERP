// --- Question Bank (Phase 1: Previous Year Papers) ---

model QuestionBankSettings {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @unique @map("tenant_id") @db.Uuid
  maxUploadMb      Int      @default(25) @map("max_upload_mb")
  allowedMimeTypes Json     @default("[]") @map("allowed_mime_types")
  allowedPaperTypes Json    @default("[]") @map("allowed_paper_types")
  studentAccessEnabled Boolean @default(true) @map("student_access_enabled")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("question_bank_settings")
  @@schema("academic")
}

model QuestionPaper {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  paperCode          String    @map("paper_code")
  paperName          String    @map("paper_name")
  academicYearId     String?   @map("academic_year_id") @db.Uuid
  programVersionId   String?   @map("program_version_id") @db.Uuid
  departmentId       String?   @map("department_id") @db.Uuid
  courseId           String?   @map("course_id") @db.Uuid
  semesterNo         Int?      @map("semester_no")
  examinationSession String?   @map("examination_session")
  paperType          String    @map("paper_type")
  paperCategory      String?   @map("paper_category")
  examMonth          Int?      @map("exam_month")
  examYear           Int?      @map("exam_year")
  durationMinutes    Int?      @map("duration_minutes")
  maxMarks           Int?      @map("max_marks")
  filePath           String?   @map("file_path")
  fileName           String?   @map("file_name")
  mimeType           String?   @map("mime_type")
  fileSizeBytes      Int?      @map("file_size_bytes")
  previewPath        String?   @map("preview_path")
  status             String    @default("DRAFT")
  keywords           String[]  @default([])
  searchText         String?   @map("search_text")
  uploadedById       String?   @map("uploaded_by_id") @db.Uuid
  publishedById      String?   @map("published_by_id") @db.Uuid
  publishedAt        DateTime? @map("published_at")
  metadata           Json      @default("{}")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  approvals   QuestionPaperApproval[]
  bookmarks   QuestionPaperBookmark[]
  accessLogs  QuestionPaperAccessLog[]
  auditLogs   QuestionBankAuditLog[]

  @@index([tenantId, courseId, examYear])
  @@index([tenantId, status])
  @@index([tenantId, paperType])
  @@index([tenantId, departmentId])
  @@index([tenantId, paperCode])
  @@map("question_papers")
  @@schema("academic")
}

model QuestionPaperApproval {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  paperId    String    @map("paper_id") @db.Uuid
  stepCode   String    @map("step_code")
  stepName   String    @map("step_name")
  roleSlug   String?   @map("role_slug")
  approverId String?   @map("approver_id") @db.Uuid
  status     String    @default("PENDING")
  comments   String?
  sequence   Int       @default(1)
  actedAt    DateTime? @map("acted_at")
  metadata   Json?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  paper QuestionPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([tenantId, paperId, status])
  @@index([tenantId, roleSlug, status])
  @@map("question_paper_approvals")
  @@schema("academic")
}

model QuestionPaperBookmark {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  paperId   String   @map("paper_id") @db.Uuid
