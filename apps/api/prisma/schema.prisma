  @@index([tenantId, accessPointId])
  @@index([tokenHash])
  @@map("access_kiosk_devices")
  @@schema("access")
}

model EntryExitLog {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  accessPointId     String   @map("access_point_id") @db.Uuid
  direction         String
