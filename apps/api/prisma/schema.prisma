  reservations LibraryReservation[]

  @@unique([tenantId, accessionNo])
  @@index([tenantId, status])
  @@index([tenantId, categoryId])
  @@index([tenantId, departmentId])
  @@index([tenantId, accessionStatus])
  @@map("library_books")
  @@schema("library")
