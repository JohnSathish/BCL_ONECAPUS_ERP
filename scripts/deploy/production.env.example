# Don Bosco College ERP — production environment
# Copy to /opt/nep-erp/.env on the VPS (never commit the real file).
#
# Server: srv1125334.hstgr.cloud (82.25.110.120)
# Domain: https://erp.donboscocollege.ac.in

# --- Database (Docker postgres on same VPS) ---
DATABASE_URL=postgresql://nep:CHANGE_ME_DB_PASSWORD@postgres:5432/nep_erp?connection_limit=20&pool_timeout=30

# --- Redis (Docker on same VPS) ---
REDIS_URL=redis://redis:6379

# --- Auth (generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))") ---
JWT_ACCESS_SECRET=CHANGE_ME_64_CHAR_RANDOM_ACCESS_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_RANDOM_REFRESH_SECRET_MIN_32_CHARS
JWT_ACCESS_TTL=1200s
JWT_REFRESH_TTL=7d
JWT_REFRESH_TTL_REMEMBER=30d

# --- Security hardening (generate fresh keys; never commit real values) ---
# PII field encryption (Aadhaar, bank details at rest)
ENCRYPTION_KEY=CHANGE_ME_64_CHAR_ENCRYPTION_KEY
# Worker backup file encryption (database.dump, files.tar.zst)
BACKUP_ENCRYPTION_KEY=CHANGE_ME_64_CHAR_BACKUP_KEY
# CSRF double-submit cookie for web cookie sessions
CSRF_ENABLED=true

# --- App URLs ---
WEB_ORIGIN=https://erp.donboscocollege.ac.in
CORS_EXTRA_ORIGINS=https://admissions.donboscocollege.ac.in,https://library.donboscocollege.ac.in
COOKIE_SECURE=true
NODE_ENV=production
HOST=0.0.0.0
API_HOST=0.0.0.0

# --- Web build / runtime ---
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_LOGIN_HOST=erp.donboscocollege.ac.in
# Never enable on production — shows demo passwords on login page
NEXT_PUBLIC_SHOW_DEMO_LOGIN=false

# --- Storage (local disk on VPS; use S3/R2 later if needed) ---
STORAGE_DRIVER=local
UPLOAD_ROOT=/data/uploads
STORAGE_ROOT=/data/storage
BACKUP_ROOT=/data/backups
# API container: run Nest export processors (student import, bulk update, course import).
PROCESS_BACKGROUND_JOBS=api
# Fee receipt PDFs run in the worker container (see docker-compose.prod.yml worker service).
FEE_RECEIPT_PDF_ON_WORKER=true

# --- Postgres container (docker-compose.yml) ---
POSTGRES_USER=nep
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=nep_erp

# --- Email (Gmail SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailconnect@donboscocollege.ac.in
SMTP_PASS=CHANGE_ME_APP_PASSWORD
SMTP_FROM=mailconnect@donboscocollege.ac.in
SMTP_FROM_NAME=Don Bosco College Tura Admissions

# --- SMS (DBCTURA gateway) ---
SMS_ENABLED=true
SMS_BASE_URL=http://164.52.195.161/API/SendMsg.aspx
SMS_USERNAME=CHANGE_ME
SMS_PASSWORD=CHANGE_ME
SMS_SENDER=DBTURA
SMS_PRIORITY=1
SMS_DLT_TEMPLATE_ID=1007651140907969622
SMS_DLT_CTA_ID=1014403420715468388
SMS_ADMISSIONS_LOGIN_URL=https://admissions.donboscocollege.ac.in/login
ADMISSIONS_PORTAL_ORIGIN=https://admissions.donboscocollege.ac.in

# --- Razorpay (live) ---
RAZORPAY_KEY_ID=CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME_FROM_RAZORPAY_DASHBOARD
ADMISSIONS_APPLICATION_FEE=600
